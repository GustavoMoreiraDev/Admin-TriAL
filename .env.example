# =============================================================================
# TriAL Smart Softwares — Configuração do Projeto
#
# 1. Copie este arquivo:  cp .env.example .env
# 2. Ajuste os valores conforme seu ambiente
# 3. Suba o projeto:      docker compose up --build
#
# O backend não precisa de .env próprio — o entrypoint gera tudo
# automaticamente a partir das variáveis abaixo.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_NAME=TriAL
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------------------------------------------------------
DB_DATABASE=trial_db
DB_USERNAME=trial_user
DB_PASSWORD=trial_pass

# -----------------------------------------------------------------------------
# JWT
# Deixe JWT_SECRET em branco — gerado automaticamente no primeiro boot.
# -----------------------------------------------------------------------------
JWT_SECRET=XyPAt1jhE15tFnIxrTYAJ7Wwzf48D67YRISSk5ChJz1h3DAz2HVeiVx8CHSv0DMv
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160

# -----------------------------------------------------------------------------
# Fila
# 'database' usa PostgreSQL e requer o serviço worker rodando (padrão Docker).
# 'sync' executa direto no processo, sem worker — útil para testes locais.
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# E-mail
# 'log' imprime em storage/logs/laravel.log (padrão para desenvolvimento).
# Para produção, troque por smtp/mailgun/ses e preencha as variáveis extras.
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@trial.local
MAIL_FROM_NAME="TriAL Platform"
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# -----------------------------------------------------------------------------
# Usuário root — criado automaticamente na primeira execução
# -----------------------------------------------------------------------------
ROOT_EMAIL=root@trial.com
ROOT_SENHA=root123
ROOT_NOME=Administrador
ROOT_TELEFONE=99999999999
ROOT_NASCIMENTO=1990-01-01

# -----------------------------------------------------------------------------
# Frontend (Vue 3 + Quasar)
# URL da API consumida pelo browser. Deve apontar para o nginx/backend.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
